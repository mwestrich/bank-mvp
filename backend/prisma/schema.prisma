generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int              @id @default(autoincrement())
  email          String           @unique @db.VarChar(255)
  full_name      String           @db.VarChar(100)
  password_hash  String
  is_verified    Boolean          @default(false)
  created_at     DateTime         @default(now())

  accounts         Account[]      @relation("UserAccounts")
  joint_accounts   Account[]      @relation("JointUserAccounts")
  funding_sources  FundingSource[]
  ris_notices      RisNotice[]

  @@map("users")
}

model Account {
  id             Int       @id @default(autoincrement())
  user_id        Int
  joint_user_id  Int?
  account_number String    @unique @db.VarChar(20)
  balance        Decimal   @default(0.00) @db.Decimal(12, 2)
  created_at     DateTime  @default(now())

  user           User      @relation("UserAccounts", fields: [user_id], references: [id], onDelete: Cascade)
  joint_user     User?     @relation("JointUserAccounts", fields: [joint_user_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([joint_user_id])
  @@index([account_number])
  @@map("accounts")
}

model Transaction {
  id             Int      @id @default(autoincrement())
  from_account   String   @db.VarChar(20)
  to_account     String   @db.VarChar(20)
  amount         Decimal  @db.Decimal(12, 2)
  type           String   @db.VarChar(20)
  description    String?
  created_at     DateTime @default(now())

  @@index([from_account])
  @@index([to_account])
  @@index([created_at])
  @@map("transactions")
}

model OtpCode {
  id         Int      @id @default(autoincrement())
  email      String   @db.VarChar(255)
  code       String   @db.VarChar(6)
  expires_at DateTime
  used       Boolean  @default(false)

  @@map("otp_codes")
}

model FundingSource {
  id            Int      @id @default(autoincrement())
  user_id       Int
  bank_name     String   @db.VarChar(100)
  account_last4 String   @db.VarChar(4)
  created_at    DateTime @default(now())

  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("funding_sources")
}

model RisNotice {
  id         Int      @id @default(autoincrement())
  user_id    Int
  amount_due Decimal  @db.Decimal(12, 2)
  status     String   @default("uncleared") @db.VarChar(20)
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@map("ris_notices")
}
